---
const year = new Date().getFullYear();
---

<footer>
  <div class="foot-brand">
    <span>PACKET<a href="/">PILOT</a>AI</span>
  </div>
  <ul class="foot-links">
    <li><a href="/blog">Blog</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="https://github.com/M-oeD/packetpilotai">GitHub</a></li>
  </ul>
  <p class="foot-copy">© {year} Packet Pilot AI &nbsp;·&nbsp; All rights reserved</p>
</footer>

<style>
  footer {
    padding: 2.5rem 2rem;
    text-align: center;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }
  .foot-brand {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .foot-brand a { color: var(--accent); }
  .foot-links {
    display: flex;
    gap: 2rem;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .foot-links a {
    font-size: 13px;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .foot-links a:hover { color: var(--accent); opacity: 1; }
  .foot-copy {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-dim);
    opacity: 0.45;
    letter-spacing: 1px;
  }
</style>
