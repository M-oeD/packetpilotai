---
import Nav from '../../../components/Nav.astro';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import { POSTS_META } from '../../../data/posts-meta';
import { STREAM_LIST, STREAMS, type StreamKey } from '../../../data/streams';
import StatusBar from '../../../components/react/StatusBar';
import FooterBar from '../../../components/react/FooterBar';
import CopilotDock from '../../../components/react/CopilotDock';
import TweaksPanel from '../../../components/react/TweaksPanel';
import NewsletterBar from '../../../components/NewsletterBar.astro';

export async function getStaticPaths() {
  return STREAM_LIST.map((s) => ({
    params: { stream: s.key },
    props: { streamKey: s.key as StreamKey },
  }));
}

interface Props {
  streamKey: StreamKey;
}

const { streamKey } = Astro.props;
const stream = STREAMS[streamKey];

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => !p.data.draft && p.data.stream === streamKey)
  .sort((a, b) => {
    const an = a.data.streamNum;
    const bn = b.data.streamNum;
    if (an && bn) return an - bn;
    if (an) return -1;
    if (bn) return 1;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    desc: p.data.description,
    date: p.data.pubDate.toISOString().slice(0, 10),
    streamNum: p.data.streamNum,
    ...(POSTS_META[p.id] ?? { tags: [], ascii: [], accent: 'ok', read: '5 min' }),
  }));
---

<!doctype html>
<html lang="en" data-theme="amber" data-density="compact">
  <head>
    <BaseHead
      title={`${stream.name} — PacketPilot AI`}
      description={stream.description}
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": stream.name,
      "description": stream.description,
      "url": `https://packetpilotai.com/series/${stream.key}/`,
      "isPartOf": {
        "@type": "WebSite",
        "name": "PacketPilot AI",
        "url": "https://packetpilotai.com"
      }
    })} />
  </head>
  <body>
    <div class="ppc-grid-bg" aria-hidden="true"></div>
    <div class="ppc-scanline" aria-hidden="true"></div>

    <StatusBar client:load />

    <Nav />

    <div class="ppc-shell">
      <main class="ppc-main">

        <section class="ppc-hero" style="margin-bottom: 32px">
          <div class="ppc-article-kicker" style="margin-bottom: 14px">
            <span class="ppc-section-bracket">[</span>
            series · {stream.key} · <span class="mono">{stream.glyph}</span>
            <span class="ppc-section-bracket">]</span>
          </div>
          <h1 class="ppc-hero-h1" style="max-width: 22ch">
            {stream.name}
          </h1>
          <p class="ppc-hero-lede">
            {stream.description}
          </p>
          <div class="ppc-hero-meta muted" style="margin-top: 16px">
            <span>{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
            <span class="sep">·</span>
            <span>{stream.cadence}</span>
            <span class="sep">·</span>
            <span class={`ppc-pill ${stream.accent}`}>{stream.short}</span>
          </div>
        </section>

        <section class="ppc-section">
          {posts.length === 0 ? (
            <div style="padding: 40px 0; border: 1px dashed var(--ppc-border); border-radius: var(--ppc-radius); text-align: center">
              <p class="mono muted" style="margin: 0 0 8px">
                <span style="color: var(--ppc-accent)">[ no posts yet in this series ]</span>
              </p>
              <p class="mono muted" style="margin: 0; font-size: 13px">
                The pillar post is in flight — check back soon, or
                <a href="/blog">browse all posts</a>.
              </p>
            </div>
          ) : (
            <div class="ppc-post-grid two">
              {posts.map((post) => (
                <article class="ppc-post">
                  <div class="ppc-post-meta">
                    {post.streamNum !== undefined && (
                      <>
                        <span class="ppc-post-date mono">#{String(post.streamNum).padStart(2, '0')}</span>
                        <span class="ppc-post-sep">·</span>
                      </>
                    )}
                    <span class="ppc-post-date">{post.date}</span>
                    <span class="ppc-post-sep">·</span>
                    <span class="muted">{post.read}</span>
                    <span class="ppc-post-sep">·</span>
                    <span class={`ppc-pill ${stream.accent}`}>{stream.short}</span>
                  </div>
                  <h3 class="ppc-post-title">
                    <a href={`/blog/${post.slug}`}>{post.title}</a>
                  </h3>
                  <p class="ppc-post-desc">{post.desc}</p>
                  {post.ascii && post.ascii.length > 0 && (
                    <pre class={`ppc-post-ascii mono accent-${post.accent}`}>{post.ascii.join('\n')}</pre>
                  )}
                  <div class="ppc-post-foot">
                    <span class="ppc-post-tags">
                      {post.tags?.map((t: string) => <span class="ppc-post-tag">#{t}</span>)}
                    </span>
                    <a class="ppc-post-link" href={`/blog/${post.slug}`}>read ▸</a>
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>

        <section class="ppc-section">
          <a href="/blog" class="ppc-link">▸ back to all posts</a>
        </section>

      </main>
    </div>

    <NewsletterBar />
    <FooterBar client:load />
    <CopilotDock client:load />
    <TweaksPanel client:load />
  </body>
</html>
