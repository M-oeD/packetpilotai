---
import Nav from '../components/Nav.astro';
import BaseHead from '../components/BaseHead.astro';
import StatusBar from '../components/react/StatusBar';
import FooterBar from '../components/react/FooterBar';
import CopilotDock from '../components/react/CopilotDock';
import TweaksPanel from '../components/react/TweaksPanel';
import NewsletterBar from '../components/NewsletterBar.astro';
import Roadmap from '../components/react/Roadmap';
import { ROADMAP, ROADMAP_NODE_COUNT, ROADMAP_POST_COUNT } from '../data/roadmap';

const title = 'AI Network Engineering Roadmap — Claude for Network Engineers | PacketPilot AI';
const description =
  'A free interactive roadmap for network engineers working with AI. Every topic — subnetting, OSPF, BGP, DNS, firewalls, automation — paired with a copy-paste Claude prompt. Track your progress in the browser.';

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'AI Network Engineering Roadmap',
  description,
  numberOfItems: ROADMAP_NODE_COUNT,
  itemListElement: ROADMAP.flatMap((d) => d.nodes).map((n, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: n.label,
  })),
};

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the AI network engineering roadmap?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'It is a free, interactive learning path that maps the network engineering stack — foundations, switching, routing, core services, performance, security, and automation — and pairs every topic with a copy-paste Claude prompt you can run immediately. Progress is saved in your browser.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is this different from a normal developer roadmap?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most roadmaps stop at "learn this topic." This one sits at the intersection of network engineering and AI: each node includes a field-tested Claude prompt for the real task, so you learn the concept and get a tool that does the work the same day.',
      },
    },
  ],
};
---

<!doctype html>
<html lang="en" data-theme="amber" data-density="compact">
  <head>
    <BaseHead title={title} description={description} />
    <script type="application/ld+json" set:html={JSON.stringify(itemList)} />
    <script type="application/ld+json" set:html={JSON.stringify(faq)} />
  </head>
  <body>
    <div class="ppc-grid-bg" aria-hidden="true"></div>
    <div class="ppc-scanline" aria-hidden="true"></div>

    <StatusBar client:load />

    <Nav />

    <div class="ppc-shell">
      <main class="rm-page">

        <header class="rm-page-head">
          <div class="ppc-article-kicker">
            <span class="ppc-section-bracket">[</span>
            roadmap · claude × network-eng
            <span class="ppc-section-bracket">]</span>
          </div>
          <h1 class="ppc-article-h1">The AI Network Engineering Roadmap</h1>
          <p class="ppc-article-lede">
            The whole stack — subnetting to BGP to firewall audits to automation — with a
            copy-paste Claude prompt on every node. Networking and AI, in one path.
            Click any node to load its console.
          </p>
          <p class="rm-page-meta mono">
            {ROADMAP_NODE_COUNT} nodes · {ROADMAP_POST_COUNT} full guides live · the rest ship as prompts today
          </p>
        </header>

        <Roadmap client:load />

        <!-- Pack CTA -->
        <section class="rm-cta">
          <div class="rm-cta-inner">
            <div class="ppc-section-kicker mono">
              <span class="ppc-section-bracket">[</span>go faster<span class="ppc-section-bracket">]</span>
            </div>
            <p class="rm-cta-text">
              Every prompt here is a sample of the system. The
              <strong>Claude Prompt Pack for Network Admins</strong> is 60+ field-tested prompts —
              config generation, troubleshooting, Python automation, security auditing — organized and ready to run.
            </p>
            <a class="ppc-btn primary" href="/prompt-pack">Get the pack · $29</a>
          </div>
        </section>

      </main>
    </div>

    <NewsletterBar />
    <FooterBar client:load />
    <CopilotDock client:load />
    <TweaksPanel client:load />

    <style>
      .rm-page { max-width: 1100px; margin: 0 auto; padding: 28px 0 24px; }
      .rm-page-head { margin-bottom: 32px; }
      .rm-page-meta { font-size: 12px; color: var(--ppc-muted); margin: 14px 0 0; }

      .rm-cta { margin-top: 48px; }
      .rm-cta-inner {
        border: 1px solid var(--ppc-accent);
        background: var(--ppc-accent-soft);
        border-radius: var(--ppc-radius);
        padding: 24px;
      }
      .rm-cta-text {
        font-size: 15px;
        line-height: 1.65;
        color: var(--ppc-text-2);
        margin: 10px 0 18px;
        max-width: 70ch;
      }
      .rm-cta-text strong { color: var(--ppc-text); }
    </style>
  </body>
</html>
