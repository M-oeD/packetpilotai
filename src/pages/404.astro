---
import BaseHead from '../components/BaseHead.astro';
import StatusBar from '../components/react/StatusBar';
import FooterBar from '../components/react/FooterBar';
import CopilotDock from '../components/react/CopilotDock';
import TweaksPanel from '../components/react/TweaksPanel';
---

<!doctype html>
<html lang="en" data-theme="amber" data-density="compact">
  <head>
    <BaseHead
      title="404 — Destination Unreachable · PacketPilot AI"
      description="That route dropped. The page you're looking for doesn't exist — here's the way back."
      noindex={true}
    />
  </head>
  <body>
    <div class="ppc-grid-bg" aria-hidden="true"></div>
    <div class="ppc-scanline" aria-hidden="true"></div>

    <StatusBar client:idle />

    <header class="ppc-nav">
      <div class="ppc-nav-inner">
        <a class="ppc-brand" href="/">
          <span class="ppc-brand-glyph" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2.5" y="2.5" width="19" height="19" rx="1" />
              <path d="M2.5 12 H 21.5 M 12 2.5 V 21.5" />
              <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <span>packet<span class="ppc-brand-em">pilot</span><span class="ppc-brand-tld">.ai</span></span>
          <span class="ppc-brand-caret">_</span>
        </a>
        <nav class="ppc-nav-items">
          <a href="/" class="ppc-nav-item">/home</a>
          <a href="/blog" class="ppc-nav-item">/blog</a>
          <a href="/prompt-pack" class="ppc-nav-item">/prompt-pack</a>
          <a href="/about" class="ppc-nav-item">/about</a>
        </nav>
        <div class="ppc-nav-cli">
          <span class="ppc-nav-prompt">~</span>
          <span class="ppc-nav-prompt-sigil">$</span>
          <span class="ppc-nav-cli-hint">press ⌘K</span>
        </div>
      </div>
    </header>

    <div class="ppc-shell">
      <div class="ppc-404">
        <div class="ppc-404-code">404</div>
        <pre class="ppc-404-trace">$ traceroute requested-page
 1  gateway            0.4 ms   0.3 ms   0.4 ms
 2  packetpilot.ai     1.1 ms   1.0 ms   1.2 ms
 3  * * *
 4  * * *  <span class="ppc-404-down">destination unreachable</span></pre>
        <h1 class="ppc-404-h1">This route dropped.</h1>
        <p class="ppc-404-lede">
          The page you requested isn't on this host. It may have moved, or the link was malformed.
          Pick a known-good next hop:
        </p>
        <div class="ppc-404-links">
          <a class="ppc-404-link" href="/">
            <span class="ppc-404-sigil" aria-hidden="true">▸</span> /home
            <span class="ppc-404-meta">back to the console</span>
          </a>
          <a class="ppc-404-link" href="/blog">
            <span class="ppc-404-sigil" aria-hidden="true">▸</span> /blog
            <span class="ppc-404-meta">network admin guides</span>
          </a>
          <a class="ppc-404-link" href="/prompt-pack">
            <span class="ppc-404-sigil" aria-hidden="true">▸</span> /prompt-pack
            <span class="ppc-404-meta">60 Claude prompts</span>
          </a>
          <a class="ppc-404-link" href="/about">
            <span class="ppc-404-sigil" aria-hidden="true">▸</span> /about
            <span class="ppc-404-meta">what this is</span>
          </a>
        </div>
        <p class="ppc-404-hint">tip: press <kbd>⌘K</kbd> to search.</p>
      </div>
    </div>

    <FooterBar client:visible />
    <CopilotDock client:idle />
    <TweaksPanel client:idle />
  </body>
</html>
