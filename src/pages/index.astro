---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { STREAM_LIST } from '../data/streams';
import StatusBar from '../components/react/StatusBar';
import HeroBoot from '../components/react/HeroBoot';
import Topology from '../components/react/Topology';
import Traceroute from '../components/react/Traceroute';
import FooterBar from '../components/react/FooterBar';
import CopilotDock from '../components/react/CopilotDock';
import TweaksPanel from '../components/react/TweaksPanel';
import NewsletterBar from '../components/NewsletterBar.astro';

const allPosts = await getCollection('blog');
const published = allPosts.filter((p) => !p.data.draft);
const publishedCount = published.length;

// Newest post in a stream first: higher streamNum wins, then newer pubDate.
const latestFirst = (a, b) => {
  const an = a.data.streamNum ?? 0;
  const bn = b.data.streamNum ?? 0;
  if (an !== bn) return bn - an;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
};

const streams = STREAM_LIST.map((s) => {
  const inStream = [...published].filter((p) => p.data.stream === s.key).sort(latestFirst);
  const latest = inStream[0];
  return {
    key: s.key,
    name: s.name,
    short: s.short,
    description: s.description,
    accent: s.accent,
    glyph: s.glyph,
    cadence: s.cadence,
    count: inStream.length,
    latestTitle: latest ? latest.data.title : null,
  };
});
---

<!doctype html>
<html lang="en" data-theme="amber" data-density="compact">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": "PacketPilot AI",
          "url": "https://packetpilotai.com",
          "description": "Terminal-first guides for network admins on troubleshooting, Cisco and pfSense configs, and AI-assisted networking workflows."
        },
        {
          "@type": "Organization",
          "name": "PacketPilot AI",
          "url": "https://packetpilotai.com",
          "description": "PacketPilot AI publishes practical guides for network administrators covering packet analysis, network troubleshooting, firewall auditing, and AI-assisted configuration generation."
        }
      ]
    })} />
  </head>
  <body>
    <div class="ppc-grid-bg" aria-hidden="true"></div>
    <div class="ppc-scanline" aria-hidden="true"></div>

    <StatusBar client:load />

    <header class="ppc-nav">
      <div class="ppc-nav-inner">
        <a class="ppc-brand" href="/">
          <span class="ppc-brand-glyph" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2.5" y="2.5" width="19" height="19" rx="1" />
              <path d="M2.5 12 H 21.5 M 12 2.5 V 21.5" />
              <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <span>packet<span class="ppc-brand-em">pilot</span><span class="ppc-brand-tld">.ai</span></span>
          <span class="ppc-brand-caret">_</span>
        </a>
        <nav class="ppc-nav-items">
          <a href="/" class="ppc-nav-item is-active">/home</a>
          <a href="/blog" class="ppc-nav-item">/blog</a>
          <a href="/prompt-pack" class="ppc-nav-item">/prompt-pack</a>
          <a href="/about" class="ppc-nav-item">/about</a>
        </nav>
        <div class="ppc-nav-cli">
          <span class="ppc-nav-prompt">~</span>
          <span class="ppc-nav-prompt-sigil">$</span>
          <span class="ppc-nav-cli-hint">press ⌘K</span>
        </div>
      </div>
    </header>

    <div class="ppc-shell">
      <main class="ppc-main">

        <!-- Hero -->
        <section class="ppc-hero">
          <div class="ppc-hero-grid">
            <div class="ppc-hero-left">
              <div class="ppc-hero-kicker">
                <span class="ppc-dot ppc-dot-ok" style="width:8px;height:8px" aria-hidden="true"></span>
                <span class="mono">v2026.04 · console build</span>
                <span class="ppc-pill accent">new · prompt pack v1</span>
              </div>
              <h1 class="ppc-hero-h1">
                Run your network<br />
                <em class="ppc-hero-em">like an operator,</em><br />
                not a tab manager.
              </h1>
              <p class="ppc-hero-lede">
                PacketPilot is a working manual for network admins in the AI era —
                terminal-first guides on troubleshooting, Cisco/pfSense configs, and
                Claude prompts that actually produce CLI-ready output.
              </p>
              <div class="ppc-hero-cta">
                <a class="ppc-btn primary" href="/blog">
                  <span class="mono">▸ ls /blog</span>
                </a>
                <a class="ppc-btn ghost mono" href="https://packetpilotai.gumroad.com/l/vepip" target="_blank" rel="noopener">
                  ▸ get prompt pack <span class="muted">$29</span>
                </a>
              </div>
              <div class="ppc-hero-meta muted">
                <span>{publishedCount} published</span>
                <span class="sep">·</span>
                <span>60 prompts</span>
                <span class="sep">·</span>
                <span>updated 2026-05-31</span>
              </div>
            </div>

            <div class="ppc-hero-right">
              <div class="ppc-hero-window">
                <div class="ppc-hero-window-bar">
                  <span class="muted">~/packetpilot</span>
                  <span class="ppc-hero-window-dots">
                    <span></span><span></span><span></span>
                  </span>
                </div>
                <HeroBoot client:load />
                <div class="ppc-hero-window-foot">
                  <span>tmux 0:console*</span>
                  <span>—</span>
                  <span>1 of 6</span>
                </div>
              </div>
              <pre class="ppc-hero-ascii mono" aria-hidden="true">{`         ╔═════════ PACKETPILOT ═════════╗
         ║                               ║
   ──────╫──▸ ▸ ▸ ▸ ▸ ▸ ▸ ▸ ▸ ▸ ▸ ▸ ▸ ▸──╫────▸  internet
         ║   client  switch  fw   wan    ║
         ╚═══════════════════════════════╝`}</pre>
            </div>
          </div>
        </section>

        <!-- Topology -->
        <section class="ppc-section">
          <div class="ppc-section-title">
            <div>
              <div class="ppc-section-kicker mono"><span class="ppc-section-bracket">[</span>topology.live<span class="ppc-section-bracket">]</span></div>
              <h2 class="ppc-section-h2">Your network, in motion.</h2>
            </div>
            <div class="ppc-section-hint muted">rendered client-side · 60fps · zero photos</div>
          </div>
          <Topology client:load />
        </section>

        <!-- Traceroute -->
        <section class="ppc-section">
          <div class="ppc-section-title">
            <div>
              <div class="ppc-section-kicker mono"><span class="ppc-section-bracket">[</span>traceroute.realtime<span class="ppc-section-bracket">]</span></div>
              <h2 class="ppc-section-h2">See where the path dies.</h2>
            </div>
            <div class="ppc-section-hint muted">mtr, but on the homepage</div>
          </div>
          <Traceroute client:load />
        </section>

        <!-- The Six Streams -->
        <section class="ppc-section">
          <div class="ppc-section-title">
            <div>
              <div class="ppc-section-kicker mono"><span class="ppc-section-bracket">[</span>the.six.streams<span class="ppc-section-bracket">]</span></div>
              <h2 class="ppc-section-h2">Six streams. One console.</h2>
            </div>
            <a href="/blog" class="ppc-link ppc-section-hint">▸ all posts</a>
          </div>
          <div class="ppc-stream-grid">
            {streams.map((s) => (
              <a class={`ppc-post ppc-stream-card accent-${s.accent}`} href={`/series/${s.key}/`}>
                <div class="ppc-post-meta">
                  <span class="ppc-stream-glyph mono">{s.glyph}</span>
                  <span class={`ppc-pill ${s.accent}`}>{s.short}</span>
                  <span class="ppc-post-sep">·</span>
                  <span class="muted">{s.cadence}</span>
                </div>
                <h3 class="ppc-post-title">{s.name}</h3>
                <p class="ppc-post-desc">{s.description}</p>
                <div class="ppc-stream-latest mono">
                  {s.latestTitle ? (
                    <><span class="muted">latest:</span> {s.latestTitle}</>
                  ) : (
                    <span class="muted">pillar in flight</span>
                  )}
                </div>
                <div class="ppc-post-foot">
                  <span class="ppc-post-tags">{s.count} {s.count === 1 ? 'post' : 'posts'}</span>
                  <span class="ppc-post-link">open ▸</span>
                </div>
              </a>
            ))}
          </div>
        </section>

        <!-- Prompt Pack -->
        <section class="ppc-section" id="pack">
          <div class="ppc-section-title">
            <div>
              <div class="ppc-section-kicker mono"><span class="ppc-section-bracket">[</span>prompt-pack.v1<span class="ppc-section-bracket">]</span></div>
              <h2 class="ppc-section-h2">60 prompts. One PDF. $29.</h2>
            </div>
            <div class="ppc-section-hint muted">ships now</div>
          </div>
          <div class="ppc-pack">
            <div class="ppc-pack-left">
              <pre class="ppc-pack-ascii mono">{`┌─ PROMPT PACK v1 ──────────────────────────────┐
│                                                │
│  ⚙  config-generation       ×  7 prompts      │
│  🔍  troubleshooting         ×  7 prompts      │
│  🐍  python & automation     ×  6 prompts      │
│  📄  documentation           ×  5 prompts      │
│  🔒  security & audit        ×  5 prompts      │
│  🤖  ai workflows            × 10 prompts      │
│  ⚡  quick-fire              × 10 prompts      │
│                                                │
│  packetpilot.ai/pack            ──── $29 ──── │
└────────────────────────────────────────────────┘`}</pre>
            </div>
            <div class="ppc-pack-right">
              <p class="ppc-pack-blurb">
                Templates with <span class="mono">[brackets]</span> for your specifics.
                Drop them into Claude, get CLI-ready output, working Python, and audit-grade docs on the first try.
              </p>
              <ul class="ppc-pack-list">
                <li><span class="ok">✓</span> works with Sonnet, Opus, Haiku</li>
                <li><span class="ok">✓</span> Cisco IOS, pfSense, Linux, Junos</li>
                <li><span class="ok">✓</span> includes Claude Project system prompts</li>
                <li><span class="ok">✓</span> lifetime updates · no subscription</li>
              </ul>
              <a class="ppc-btn primary" href="https://packetpilotai.gumroad.com/l/vepip" target="_blank" rel="noopener">
                <span class="mono">▸ get the pack · $29</span>
              </a>
            </div>
          </div>
        </section>

      </main>
    </div>

    <NewsletterBar />
    <FooterBar client:load />
    <CopilotDock client:load />
    <TweaksPanel client:load />
  </body>
</html>
