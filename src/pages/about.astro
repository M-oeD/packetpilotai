---
import BaseHead from '../components/BaseHead.astro';
import StatusBar from '../components/react/StatusBar';
import FooterBar from '../components/react/FooterBar';
import CopilotDock from '../components/react/CopilotDock';
import TweaksPanel from '../components/react/TweaksPanel';
---

<!doctype html>
<html lang="en" data-theme="amber" data-density="compact">
  <head>
    <BaseHead
      title="About — PacketPilot AI"
      description="PacketPilot AI is built by network admins, for network admins — practical guides on troubleshooting, AI automation, and CLI-ready networking workflows."
    />
  </head>
  <body>
    <div class="ppc-grid-bg" aria-hidden="true"></div>
    <div class="ppc-scanline" aria-hidden="true"></div>

    <StatusBar client:load />

    <header class="ppc-nav">
      <div class="ppc-nav-inner">
        <a class="ppc-brand" href="/">
          <span class="ppc-brand-glyph" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2.5" y="2.5" width="19" height="19" rx="1" />
              <path d="M2.5 12 H 21.5 M 12 2.5 V 21.5" />
              <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <span>packet<span class="ppc-brand-em">pilot</span><span class="ppc-brand-tld">.ai</span></span>
          <span class="ppc-brand-caret">_</span>
        </a>
        <nav class="ppc-nav-items">
          <a href="/" class="ppc-nav-item">/home</a>
          <a href="/blog" class="ppc-nav-item">/blog</a>
          <a href="/prompt-pack" class="ppc-nav-item">/prompt-pack</a>
          <a href="/about" class="ppc-nav-item is-active">/about</a>
        </nav>
        <div class="ppc-nav-cli">
          <span class="ppc-nav-prompt">~</span>
          <span class="ppc-nav-prompt-sigil">$</span>
          <span class="ppc-nav-cli-hint">press ⌘K</span>
        </div>
      </div>
    </header>

    <div class="ppc-shell">
      <main class="ppc-main">

        <!-- Hero -->
        <section class="ppc-hero" style="margin-bottom:32px">
          <div class="ppc-article-kicker" style="margin-bottom:14px">
            <span class="ppc-section-bracket">[</span>about.system<span class="ppc-section-bracket">]</span>
          </div>
          <h1 class="ppc-hero-h1" style="max-width:22ch">
            Built by network admins,<br /><em class="ppc-hero-em">for network admins.</em>
          </h1>
        </section>

        <!-- 2-column content -->
        <section class="ppc-section" style="margin-top:0;display:grid;grid-template-columns:1fr 340px;gap:40px;align-items:start">
          <div>
            <p style="font-size:17px;line-height:1.7;color:var(--ppc-text-2);margin:0 0 20px">
              PacketPilot AI started as a personal notebook — a place to document the workflows, prompt patterns,
              and CLI sequences that actually work in production, not the sanitized examples you find in vendor docs.
            </p>
            <p style="font-size:16px;line-height:1.7;color:var(--ppc-muted);margin:0 0 20px">
              The goal is simple: every guide should end with something you can copy into a terminal or paste into Claude
              and get a useful result on the first try. No hand-waving, no "consult your vendor." Real commands,
              real output, real root causes.
            </p>
            <p style="font-size:16px;line-height:1.7;color:var(--ppc-muted);margin:0 0 32px">
              AI tools like Claude are genuinely useful for network automation — but only if you know how to prompt them
              correctly for networking contexts. That's what the prompt pack is for, and why every blog post includes
              the Claude workflow alongside the CLI commands.
            </p>

            <div style="border-top:1px dashed var(--ppc-border-soft);padding-top:24px">
              <div class="ppc-section-kicker mono" style="margin-bottom:12px">
                <span class="ppc-section-bracket">[</span>contact<span class="ppc-section-bracket">]</span>
              </div>
              <p style="font-size:14px;color:var(--ppc-muted);margin:0 0 8px">
                Questions, feedback, or just want to talk networking:
              </p>
              <a class="mono" href="mailto:mc69080vill@gmail.com" style="color:var(--ppc-accent);font-size:14px">
                mc69080vill@gmail.com
              </a>
            </div>
          </div>

          <!-- whoami card -->
          <div class="ppc-topo" style="position:sticky;top:80px">
            <div class="ppc-card-head">
              <span class="mono kicker">whoami</span>
              <span class="ppc-dot ppc-dot-ok" style="width:8px;height:8px" aria-hidden="true"></span>
            </div>
            <pre class="mono" style="font-size:12px;padding:18px;margin:0;line-height:1.8;color:var(--ppc-text-2)">{`role      network admin / netsec
focus     ai-assisted networking
stack     cisco · pfsense · linux
tools     claude · netmiko · wireshark
location  midwest, US
contact   mc69080vill@gmail.com
site      packetpilotai.com`}</pre>
          </div>
        </section>

      </main>
    </div>

    <FooterBar client:load />
    <CopilotDock client:load />
    <TweaksPanel client:load />
  </body>
</html>
