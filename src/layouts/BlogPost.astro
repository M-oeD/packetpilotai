---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import { POSTS_META } from '../data/posts-meta';
import { OG_IMAGE, SITE_AUTHOR } from '../consts';
import { absoluteUrl, blogPostingSchema, breadcrumbSchema, faqPageSchema } from '../utils/schema';
import StatusBar from '../components/react/StatusBar';
import FooterBar from '../components/react/FooterBar';
import CopilotDock from '../components/react/CopilotDock';
import TweaksPanel from '../components/react/TweaksPanel';

type RelatedPost = { slug: string; title: string; read: string; tag: string };
type Props = CollectionEntry<'blog'>['data'] & { id: string; related?: RelatedPost[] };

const { title, description, pubDate, updatedDate, heroAscii, image, draft, id, faqs = [], related = [] } = Astro.props;
const meta = POSTS_META[id] ?? { tags: [], read: '5 min', accent: 'ok', ascii: [] };
const dateStr = pubDate.toISOString().slice(0, 10);
const updatedStr = updatedDate?.toISOString().slice(0, 10);
const tagLabel = meta.tags[0] ?? 'guide';

// SEO metadata: full ISO dates + absolute URLs for structured data.
const postPath = `/blog/${id}/`;
const postUrl = absoluteUrl(postPath, Astro.site);
const ogImage = image ?? OG_IMAGE;
const imageUrl = absoluteUrl(ogImage, Astro.site);
const publishedISO = pubDate.toISOString();
const modifiedISO = (updatedDate ?? pubDate).toISOString();

const jsonLd = [
	blogPostingSchema(
		{
			title,
			description,
			url: postUrl,
			image: imageUrl,
			datePublished: publishedISO,
			dateModified: modifiedISO,
			keywords: meta.tags,
		},
		Astro.site,
	),
	breadcrumbSchema(
		[
			{ name: 'Home', path: '/' },
			{ name: 'Blog', path: '/blog/' },
			{ name: title, path: postPath },
		],
		Astro.site,
	),
];
if (faqs.length > 0) jsonLd.push(faqPageSchema(faqs));
---

<!doctype html>
<html lang="en" data-theme="amber" data-density="compact">
  <head>
    <BaseHead
      title={`${title} — PacketPilot AI`}
      description={description}
      type="article"
      image={ogImage}
      publishedTime={publishedISO}
      modifiedTime={modifiedISO}
      author={SITE_AUTHOR}
      tags={meta.tags}
      noindex={draft === true}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <div class="ppc-grid-bg" aria-hidden="true"></div>
    <div class="ppc-scanline" aria-hidden="true"></div>

    <StatusBar client:idle />

    <header class="ppc-nav">
      <div class="ppc-nav-inner">
        <a class="ppc-brand" href="/">
          <span class="ppc-brand-glyph" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2.5" y="2.5" width="19" height="19" rx="1" />
              <path d="M2.5 12 H 21.5 M 12 2.5 V 21.5" />
              <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none" />
            </svg>
          </span>
          <span>packet<span class="ppc-brand-em">pilot</span><span class="ppc-brand-tld">.ai</span></span>
          <span class="ppc-brand-caret">_</span>
        </a>
        <nav class="ppc-nav-items">
          <a href="/" class="ppc-nav-item">/home</a>
          <a href="/blog" class="ppc-nav-item is-active">/blog</a>
          <a href="/prompt-pack" class="ppc-nav-item">/prompt-pack</a>
          <a href="/about" class="ppc-nav-item">/about</a>
        </nav>
        <div class="ppc-nav-cli">
          <span class="ppc-nav-prompt">~</span>
          <span class="ppc-nav-prompt-sigil">$</span>
          <span class="ppc-nav-cli-hint">press ⌘K</span>
        </div>
      </div>
    </header>

    <div class="ppc-shell">
      <div class="ppc-article">
        <header class="ppc-article-header">
          <div class="ppc-article-kicker">
            <span class="ppc-section-bracket">[</span>
            post · {tagLabel}
            <span class="ppc-section-bracket">]</span>
          </div>
          <div class="ppc-article-meta">
            <span>{dateStr}</span>
            {updatedStr && <><span>·</span><span>updated {updatedStr}</span></>}
            <span>·</span>
            <span>{meta.read}</span>
            <span>·</span>
            <span class={`ppc-pill ${meta.accent}`}>{tagLabel}</span>
          </div>
          <h1 class="ppc-article-h1">{title}</h1>
          <p class="ppc-article-lede">{description}</p>
        </header>

        {heroAscii && (
          <pre class="ppc-article-ascii">{heroAscii}</pre>
        )}

        <div class="ppc-prose">
          <slot />
        </div>

        {faqs.length > 0 && (
          <section class="ppc-faq" aria-label="Frequently asked questions">
            <div class="ppc-faq-kicker">
              <span class="ppc-section-bracket">[</span>
              faq
              <span class="ppc-section-bracket">]</span>
            </div>
            <dl class="ppc-faq-list">
              {faqs.map((f: { q: string; a: string }) => (
                <div class="ppc-faq-item">
                  <dt class="ppc-faq-q">
                    <span class="ppc-faq-sigil" aria-hidden="true">?</span>
                    {f.q}
                  </dt>
                  <dd class="ppc-faq-a">{f.a}</dd>
                </div>
              ))}
            </dl>
          </section>
        )}

        {related.length > 0 && (
          <section class="ppc-related" aria-label="Related posts">
            <div class="ppc-related-kicker">
              <span class="ppc-section-bracket">[</span>
              related
              <span class="ppc-section-bracket">]</span>
            </div>
            <ul class="ppc-related-list">
              {related.map((r) => (
                <li class="ppc-related-item">
                  <a class="ppc-related-link" href={`/blog/${r.slug}/`}>
                    <span class="ppc-related-sigil" aria-hidden="true">▸</span>
                    <span class="ppc-related-title">{r.title}</span>
                    <span class="ppc-related-meta">{r.tag} · {r.read}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        <footer class="ppc-article-footer">
          <div class="ppc-article-tags">
            {meta.tags.map((t: string) => (
              <a class="ppc-article-tag" href={`/blog`}>#{t}</a>
            ))}
          </div>
          <a class="ppc-link" href="/blog">▸ all posts</a>
        </footer>
      </div>
    </div>

    <FooterBar client:visible />
    <CopilotDock client:idle />
    <TweaksPanel client:idle />
  </body>
</html>
