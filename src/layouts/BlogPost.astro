---
import Nav from '../components/Nav.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import { POSTS_META } from '../data/posts-meta';
import StatusBar from '../components/react/StatusBar';
import FooterBar from '../components/react/FooterBar';
import CopilotDock from '../components/react/CopilotDock';
import TweaksPanel from '../components/react/TweaksPanel';

type Props = CollectionEntry<'blog'>['data'] & { id: string };

const { title, description, pubDate, updatedDate, heroAscii, id } = Astro.props;
const meta = POSTS_META[id] ?? { tags: [], read: '5 min', accent: 'ok', ascii: [], faq: [], related: [] };
const dateStr = pubDate.toISOString().slice(0, 10);
const updatedStr = updatedDate?.toISOString().slice(0, 10);
const tagLabel = meta.tags[0] ?? 'guide';

// Fetch related posts for the internal linking section
const allPosts = await getCollection('blog');
const relatedPosts = (meta.related ?? [])
  .map((slug: string) => allPosts.find((p) => p.id === slug || p.slug === slug))
  .filter(Boolean) as CollectionEntry<'blog'>[];

const faqItems = meta.faq ?? [];
---

<!doctype html>
<html lang="en" data-theme="amber" data-density="compact">
  <head>
    <BaseHead title={`${title} — PacketPilot AI`} description={description} />

    <!-- Article schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": dateStr,
      "dateModified": updatedStr ?? dateStr,
      "url": Astro.url.href,
      "author": {
        "@type": "Organization",
        "name": "PacketPilot AI",
        "url": "https://packetpilotai.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "PacketPilot AI",
        "url": "https://packetpilotai.com"
      }
    })} />

    <!-- FAQPage schema — picked up by ChatGPT, Perplexity, and Google AI Overviews -->
    {faqItems.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map((item: { q: string; a: string }) => ({
          "@type": "Question",
          "name": item.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.a
          }
        }))
      })} />
    )}
  </head>
  <body>
    <div class="ppc-grid-bg" aria-hidden="true"></div>
    <div class="ppc-scanline" aria-hidden="true"></div>

    <StatusBar client:load />

    <Nav />

    <div class="ppc-shell">
      <div class="ppc-article">
        <header class="ppc-article-header">
          <div class="ppc-article-kicker">
            <span class="ppc-section-bracket">[</span>
            post · {tagLabel}
            <span class="ppc-section-bracket">]</span>
          </div>
          <div class="ppc-article-meta">
            <span>{dateStr}</span>
            {updatedStr && <><span>·</span><span>updated {updatedStr}</span></>}
            <span>·</span>
            <span>{meta.read}</span>
            <span>·</span>
            <span class={`ppc-pill ${meta.accent}`}>{tagLabel}</span>
          </div>
          <h1 class="ppc-article-h1">{title}</h1>
          <p class="ppc-article-lede">{description}</p>
        </header>

        {heroAscii && (
          <pre class="ppc-article-ascii">{heroAscii}</pre>
        )}

        <div class="ppc-prose">
          <slot />
        </div>

        <!-- FAQ section — visible on page + in schema above -->
        {faqItems.length > 0 && (
          <section class="ppc-faq" aria-label="Frequently Asked Questions">
            <div class="ppc-faq-header">
              <span class="ppc-section-bracket">[</span>
              <span class="ppc-faq-label">FAQ</span>
              <span class="ppc-section-bracket">]</span>
              <span class="ppc-faq-rule" aria-hidden="true"></span>
            </div>
            {faqItems.map((item: { q: string; a: string }) => (
              <div class="ppc-faq-item">
                <p class="ppc-faq-q">
                  <span class="ppc-faq-sigil">Q:</span>
                  {item.q}
                </p>
                <p class="ppc-faq-a">
                  <span class="ppc-faq-sigil ok">A:</span>
                  {item.a}
                </p>
              </div>
            ))}
          </section>
        )}

        <!-- Inline subscribe CTA — highest conversion point: end of article -->
        <aside class="ppc-subscribe-cta">
          <div class="ppc-subscribe-inner">
            <div class="ppc-subscribe-label">
              <span class="ppc-section-bracket">[</span>
              free · cli cheatsheet pdf
              <span class="ppc-section-bracket">]</span>
            </div>
            <p class="ppc-subscribe-text">
              60+ essential commands for triage, capture, and DNS debugging. No spam — unsubscribe anytime.
            </p>
            <script is:inline async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="29f9e65f-4f54-4279-84c7-13b055c79420"></script>
          </div>
        </aside>

        <!-- Related posts — internal linking for SEO + reader flow -->
        {relatedPosts.length > 0 && (
          <section class="ppc-related" aria-label="Related posts">
            <div class="ppc-related-header">
              <span class="ppc-section-bracket">[</span>
              <span>related</span>
              <span class="ppc-section-bracket">]</span>
            </div>
            <div class="ppc-related-grid">
              {relatedPosts.map((post) => {
                const pm = POSTS_META[post.id] ?? POSTS_META[post.slug] ?? { tags: [], accent: 'ok', read: '5 min' };
                return (
                  <a class="ppc-related-card" href={`/blog/${post.slug}`}>
                    <span class={`ppc-dot ${pm.accent}`}></span>
                    <span class="ppc-related-title">{post.data.title}</span>
                    <span class="ppc-related-read muted">{pm.read}</span>
                  </a>
                );
              })}
            </div>
          </section>
        )}

        <footer class="ppc-article-footer">
          <div class="ppc-article-tags">
            {meta.tags.map((t: string) => (
              <a class="ppc-article-tag" href={`/blog`}>#{t}</a>
            ))}
          </div>
          <a class="ppc-link" href="/blog">▸ all posts</a>
        </footer>
      </div>
    </div>

    <FooterBar client:load />
    <CopilotDock client:load />
    <TweaksPanel client:load />
  </body>
</html>

<style>
/* FAQ section */
.ppc-faq {
  margin: 2.5rem 0 2rem;
  border-top: 1px solid var(--c-border, rgba(255,255,255,0.08));
  padding-top: 1.5rem;
}

.ppc-faq-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-accent);
  margin-bottom: 1.25rem;
}

.ppc-faq-rule {
  flex: 1;
  height: 1px;
  background: var(--c-border, rgba(255,255,255,0.08));
}

.ppc-faq-label {
  color: var(--c-accent);
}

.ppc-faq-item {
  margin-bottom: 1.25rem;
  padding: 0.875rem 1rem;
  background: rgba(255,255,255,0.025);
  border: 1px solid var(--c-border, rgba(255,255,255,0.07));
  border-radius: 3px;
}

.ppc-faq-q,
.ppc-faq-a {
  margin: 0;
  font-size: 0.83rem;
  line-height: 1.65;
  font-family: var(--font-mono);
}

.ppc-faq-q {
  color: var(--c-fg, #e8e6d9);
  margin-bottom: 0.5rem;
  font-weight: 600;
}

.ppc-faq-a {
  color: var(--c-muted, rgba(232,230,217,0.65));
}

.ppc-faq-sigil {
  display: inline-block;
  margin-right: 0.5rem;
  color: var(--c-warn, #e8a000);
  font-weight: 700;
  font-size: 0.72rem;
}

.ppc-faq-sigil.ok {
  color: var(--c-ok, #00c853);
}

/* Related posts section */
.ppc-related {
  margin: 2rem 0 1.5rem;
  border-top: 1px solid var(--c-border, rgba(255,255,255,0.08));
  padding-top: 1.5rem;
}

.ppc-related-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-muted, rgba(232,230,217,0.55));
  margin-bottom: 1rem;
}

.ppc-related-grid {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.ppc-related-card {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.6rem 0.875rem;
  background: rgba(255,255,255,0.02);
  border: 1px solid var(--c-border, rgba(255,255,255,0.06));
  border-radius: 3px;
  text-decoration: none;
  transition: border-color 0.15s, background 0.15s;
}

.ppc-related-card:hover {
  background: rgba(255,255,255,0.045);
  border-color: var(--c-accent);
}

.ppc-related-title {
  flex: 1;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--c-fg, #e8e6d9);
}

.ppc-related-read {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  white-space: nowrap;
}

/* Inline subscribe CTA */
.ppc-subscribe-cta {
  margin: 2rem 0;
  border: 1px solid var(--c-accent);
  border-radius: 4px;
  background: rgba(57, 208, 216, 0.04);
  padding: 1.25rem 1.25rem 1.1rem;
}

.ppc-subscribe-label {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-accent);
  margin-bottom: 0.5rem;
}

.ppc-subscribe-text {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  line-height: 1.6;
  color: var(--c-fg);
  margin: 0 0 0.9rem;
}

</style>
