---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroAscii } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>

				<!-- ASCII terminal hero -->
				{heroAscii && (
					<div class="ascii-hero">
						<div class="ascii-bar">
							<div class="ascii-dots">
								<span class="dot r"></span>
								<span class="dot y"></span>
								<span class="dot g"></span>
							</div>
							<span class="ascii-bar-title">packetpilotai.com — terminal</span>
						</div>
						<pre class="ascii-body">{heroAscii}</pre>
					</div>
				)}

				<!-- Fallback image hero -->
				{!heroAscii && heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}

				<div class="prose">
					<div class="post-header">
						<p class="post-date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated"> · Updated <FormattedDate date={updatedDate} /></span>
							)}
						</p>
						<h1>{title}</h1>
						<p class="post-desc">{description}</p>
						<div class="post-rule"></div>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		background: var(--bg);
		color: var(--text);
	}

	main {
		max-width: 780px;
		margin: 0 auto;
		padding: 0 1.5rem 6rem;
	}

	/* ── ASCII HERO ── */
	.ascii-hero {
		border: 1px solid var(--border);
		background: var(--panel);
		margin: 2.5rem 0 3rem;
		overflow: hidden;
	}
	.ascii-bar {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 1rem;
		background: var(--panel2, #0d1117);
		border-bottom: 1px solid var(--border);
	}
	.ascii-dots {
		display: flex;
		gap: 6px;
	}
	.dot {
		width: 11px;
		height: 11px;
		border-radius: 50%;
		display: inline-block;
	}
	.dot.r { background: #ff5f57; }
	.dot.y { background: #febc2e; }
	.dot.g { background: #28c840; }
	.ascii-bar-title {
		font-family: 'Share Tech Mono', monospace;
		font-size: 11px;
		color: var(--text-dim);
		letter-spacing: 1px;
	}
	.ascii-body {
		font-family: 'Share Tech Mono', monospace;
		font-size: 13px;
		line-height: 1.7;
		color: var(--accent);
		padding: 1.75rem 2rem;
		margin: 0;
		white-space: pre;
		overflow-x: auto;
		background: transparent;
	}

	/* ── IMAGE HERO ── */
	.hero-image {
		margin: 2.5rem 0 3rem;
	}
	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 4px;
	}

	/* ── POST HEADER ── */
	.prose {
		width: 100%;
		max-width: 100%;
	}
	.post-header {
		margin-bottom: 3rem;
	}
	.post-date {
		font-family: 'Share Tech Mono', monospace;
		font-size: 11px;
		color: var(--accent);
		letter-spacing: 2px;
		text-transform: uppercase;
		margin-bottom: 1rem;
	}
	.updated {
		color: var(--text-dim);
	}
	.post-header h1 {
		font-family: 'Orbitron', monospace;
		font-weight: 900;
		font-size: clamp(1.6rem, 4vw, 2.6rem);
		color: var(--text-bright);
		line-height: 1.15;
		margin: 0 0 1rem;
		letter-spacing: -0.5px;
	}
	.post-desc {
		font-size: 16px;
		color: var(--text-dim);
		line-height: 1.75;
		margin: 0 0 2rem;
		max-width: 600px;
	}
	.post-rule {
		height: 1px;
		background: var(--border);
		width: 100%;
	}

	/* ── PROSE CONTENT ── */
	.prose :global(h2) {
		font-family: 'Orbitron', monospace;
		font-weight: 800;
		font-size: 1.2rem;
		color: var(--text-bright);
		margin: 3rem 0 1rem;
		letter-spacing: 0.3px;
	}
	.prose :global(h3) {
		font-family: 'Orbitron', monospace;
		font-weight: 700;
		font-size: 1rem;
		color: var(--text-bright);
		margin: 2rem 0 0.75rem;
	}
	.prose :global(p) {
		font-size: 16px;
		line-height: 1.8;
		color: var(--text);
		margin-bottom: 1.5rem;
	}
	.prose :global(ul), .prose :global(ol) {
		padding-left: 1.5rem;
		margin-bottom: 1.5rem;
	}
	.prose :global(li) {
		font-size: 16px;
		line-height: 1.75;
		color: var(--text);
		margin-bottom: 0.4rem;
	}
	.prose :global(a) {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid rgba(0, 240, 255, 0.3);
		transition: border-color 0.2s;
	}
	.prose :global(a:hover) {
		border-color: var(--accent);
		opacity: 1;
	}
	.prose :global(strong) {
		color: var(--text-bright);
		font-weight: 700;
	}
	.prose :global(code) {
		font-family: 'Share Tech Mono', monospace;
		font-size: 13px;
		color: var(--accent);
		background: var(--panel);
		padding: 2px 6px;
		border: 1px solid var(--border);
	}
	.prose :global(pre) {
		background: var(--panel);
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		padding: 1.5rem;
		overflow-x: auto;
		margin-bottom: 2rem;
	}
	.prose :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		font-size: 13px;
		color: var(--text);
		line-height: 1.6;
	}
	.prose :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: 2rem;
		font-size: 14px;
	}
	.prose :global(th) {
		font-family: 'Share Tech Mono', monospace;
		font-size: 11px;
		color: var(--accent);
		letter-spacing: 1.5px;
		text-transform: uppercase;
		padding: 0.75rem 1rem;
		border-bottom: 1px solid var(--accent);
		text-align: left;
	}
	.prose :global(td) {
		padding: 0.75rem 1rem;
		border-bottom: 1px solid var(--border);
		color: var(--text);
		vertical-align: top;
	}
	.prose :global(tr:last-child td) {
		border-bottom: none;
	}
	.prose :global(blockquote) {
		border-left: 3px solid var(--accent);
		padding: 0.5rem 1.5rem;
		margin: 0 0 1.5rem;
		background: var(--panel);
	}
	.prose :global(blockquote p) {
		color: var(--text-dim);
		font-style: italic;
		margin: 0;
	}
	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2.5rem 0;
	}
</style>
